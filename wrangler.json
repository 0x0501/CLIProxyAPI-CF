{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "vite-react-template",
	"main": "./src/index.ts",
	"compatibility_date": "2026-04-05",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"containers": [
		{
			"class_name": "MyContainer",
			"image": "./Dockerfile",
			"max_instances": 5
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "MyContainer",
				"name": "MY_CONTAINER"
			}
		]
	},
	"migrations": [
		{
			"new_sqlite_classes": [
				"MyContainer"
			],
			"tag": "v1"
		}
	],
	"vars": {
		"R2_BUCKET_NAME": "cli-proxy-api"
	},
	"upload_source_maps": true
}
